      "description": "The state required for the account holder.\n> Permitted values: `Processing`, `Payout`.",
      "enum": [
        "LimitedPayout",
        "LimitedProcessing",
        "LimitlessPayout",
        "LimitlessProcessing",
        "Payout",
        "Processing"
      ],
      "type": "string"
    },
    "tier": {
      "description": "The tier required for the account holder.",
      "type": "int32"
    }
  },
  "required": [
    "accountHolderCode",
    "accountStateType",
    "tier"
  ],
  "name": "PerformVerificationRequest"
}