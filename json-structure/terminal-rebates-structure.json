{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/adyen/refs/heads/main/json-structure/terminal-rebates-structure.json",
  "description": "Rebates schema from Adyen API",
  "type": "object",
  "properties": {
    "TotalRebate": {
      "type": "double",
      "maximum": 99999999.999999,
      "minimum": 0
    },
    "RebateLabel": {
      "type": "string",
      "pattern": "^.+$"
    },
    "SaleItemRebate": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/SaleItemRebate"
      }
    }
  },
  "name": "Rebates"
}