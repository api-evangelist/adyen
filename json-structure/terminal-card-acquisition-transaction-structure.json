{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/adyen/refs/heads/main/json-structure/terminal-card-acquisition-transaction-structure.json",
  "description": "CardAcquisitionTransaction schema from Adyen API",
  "type": "object",
  "properties": {
    "AllowedPaymentBrand": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^.+$"
      }
    },
    "AllowedLoyaltyBrand": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^.+$"
      }
    },
    "LoyaltyHandling": {
      "$ref": "#/components/schemas/LoyaltyHandling"
    },
    "CustomerLanguage": {
      "type": "string",
      "pattern": "^[a-z]{2,2}$"
    },
    "ForceEntryMode": {
      "$ref": "#/components/schemas/ForceEntryMode"
    },
    "ForceCustomerSelectionFlag": {
      "type": "boolean"
    },
    "TotalAmount": {
      "type": "double",
      "maximum": 99999999.999999,
      "minimum": 0
    },
    "PaymentType": {
      "$ref": "#/components/schemas/PaymentType"
    },
    "CashBackFlag": {
      "type": "boolean"
    }
  },
  "name": "CardAcquisitionTransaction"
}