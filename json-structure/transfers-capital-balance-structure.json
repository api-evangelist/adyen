{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/adyen/refs/heads/main/json-structure/transfers-capital-balance-structure.json",
  "description": "CapitalBalance schema from Adyen API",
  "type": "object",
  "properties": {
    "currency": {
      "description": "The three-character [ISO currency code](https://docs.adyen.com/development-resources/currency-codes).",
      "type": "string"
    },
    "fee": {
      "description": "Fee amount.",
      "type": "int64"
    },
    "principal": {
      "description": "Principal amount.",
      "type": "int64"
    },
    "total": {
      "description": "Total amount. A sum of principal amount and fee amount.",
      "type": "int64"
    }
  },
  "required": [
    "principal",
    "fee",
    "total",
    "currency"
  ],
  "name": "CapitalBalance"
}