{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/adyen/refs/heads/main/json-structure/management-file-structure.json",
  "description": "File schema from Adyen API",
  "type": "object",
  "properties": {
    "data": {
      "description": "The certificate content converted to a Base64-encoded string.",
