{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/adyen/refs/heads/main/json-structure/payments-device-render-options-structure.json",
  "description": "DeviceRenderOptions schema from Adyen API",
  "type": "object",
  "properties": {
    "sdkInterface": {
      "default": "both",
      "description": "Supported SDK interface types.\nAllowed values:\n* native\n* html\n* both",
      "enum": [
        "native",
        "html",
        "both"
      ],
      "type": "string"
    },
    "sdkUiType": {
      "description": "UI types supported for displaying specific challenges.\nAllowed values:\n* text\n* singleSelect\n* outOfBand\n* otherHtml\n* multiSelect",
      "items": {
        "enum": [
          "multiSelect",
          "otherHtml",
          "outOfBand",
          "singleSelect",
          "text"
        ],
        "type": "string"
      },
      "type": "array"
    }
  },
  "name": "DeviceRenderOptions"
}