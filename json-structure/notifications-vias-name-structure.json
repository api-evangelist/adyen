{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/adyen/refs/heads/main/json-structure/notifications-vias-name-structure.json",
  "description": "ViasName schema from Adyen API",
  "type": "object",
  "properties": {
    "firstName": {
      "description": "The first name.",
      "maxLength": 80,
      "type": "string"
    },
    "gender": {
      "description": "The gender.\n>The following values are permitted: `MALE`, `FEMALE`, `UNKNOWN`.",
      "enum": [
        "MALE",
        "FEMALE",
        "UNKNOWN"
      ],
      "maxLength": 1,
      "type": "string"
    },
    "infix": {
      "description": "The name's infix, if applicable.\n>A maximum length of twenty (20) characters is imposed.",
      "maxLength": 20,
      "type": "string"
    },
    "lastName": {
      "description": "The last name.",
      "maxLength": 80,
      "type": "string"
    }
  },
  "name": "ViasName"
}