{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "TransferRouteRequest": "adyen:TransferRouteRequest",
    "TransferRouteResponse": "adyen:TransferRouteResponse",
    "TransferRoute": "adyen:TransferRoute",
    "balanceAccountId": {
      "@id": "adyen:balanceAccountId",
      "@type": "xsd:string"
    },
    "balancePlatform": {
      "@id": "adyen:balancePlatform",
      "@type": "xsd:string"
    },
    "category": {
      "@id": "adyen:category",
      "@type": "xsd:string"
    },
    "counterparty": {
      "@id": "adyen:counterparty",
      "@type": "xsd:string"
    },
    "country": {
      "@id": "adyen:country",
      "@type": "xsd:string"
    },
    "currency": {
      "@id": "adyen:currency",
      "@type": "xsd:string"
    },
    "priorities": {
      "@id": "adyen:priorities",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "transferRoutes": {
      "@id": "adyen:transferRoutes",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "priority": {
      "@id": "adyen:priority",
      "@type": "xsd:string"
    },
    "requirements": {
      "@id": "adyen:requirements",
      "@type": "xsd:string"
    }
  }
}