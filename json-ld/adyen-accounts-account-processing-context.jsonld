{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "AccountProcessingState": "adyen:AccountProcessingState",
    "disableReason": {
      "@id": "adyen:disableReason",
      "@type": "xsd:string"
    },
    "disabled": {
      "@id": "adyen:disabled",
      "@type": "xsd:boolean"
    },
    "processedFrom": {
      "@id": "adyen:processedFrom",
      "@type": "xsd:string"
    },
    "processedTo": {
      "@id": "adyen:processedTo",
      "@type": "xsd:string"
    },
    "tierNumber": {
      "@id": "adyen:tierNumber",
      "@type": "xsd:integer"
    }
  }
}