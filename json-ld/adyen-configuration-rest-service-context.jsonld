{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "RestServiceError": "adyen:RestServiceError",
    "detail": {
      "@id": "adyen:detail",
      "@type": "xsd:string"
    },
    "errorCode": {
      "@id": "adyen:errorCode",
      "@type": "xsd:string"
    },
    "instance": {
      "@id": "adyen:instance",
      "@type": "xsd:string"
    },
    "invalidFields": {
      "@id": "adyen:invalidFields",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "requestId": {
      "@id": "adyen:requestId",
      "@type": "xsd:string"
    },
    "response": {
      "@id": "adyen:response",
      "@type": "xsd:string"
    },
    "status": {
      "@id": "adyen:status",
      "@type": "xsd:integer"
    },
    "title": {
      "@id": "adyen:title",
      "@type": "xsd:string"
    },
    "type": {
      "@id": "adyen:type",
      "@type": "xsd:string"
    }
  }
}