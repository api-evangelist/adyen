      "@type": "xsd:string"
    },
    "legalArrangementEntityCode": {
      "@id": "adyen:legalArrangementEntityCode",
      "@type": "xsd:string"
    },
    "shareholderCode": {
      "@id": "adyen:shareholderCode",
      "@type": "xsd:string"
    }
  }
}