{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "CheckoutDelegatedAuthenticationAction": "adyen:CheckoutDelegatedAuthenticationAction",
    "authorisationToken": {
      "@id": "adyen:authorisationToken",
      "@type": "xsd:string"
    },
    "paymentData": {
      "@id": "adyen:paymentData",
      "@type": "xsd:string"
    },
    "paymentMethodType": {
      "@id": "adyen:paymentMethodType",
      "@type": "xsd:string"
    },
    "token": {
      "@id": "adyen:token",
      "@type": "xsd:string"
    },
    "type": {
      "@id": "adyen:type",
      "@type": "xsd:string"
    },
    "url": "schema:url"
  }
}