    },
    "refunds": {
      "@id": "adyen:refunds",
      "@type": "xsd:string"
    },
    "signature": {
      "@id": "adyen:signature",
      "@type": "xsd:string"
    },
    "standalone": {
      "@id": "adyen:standalone",
      "@type": "xsd:string"
    },
    "surcharge": {
      "@id": "adyen:surcharge",
