{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "CustomerOrderReq": "adyen:CustomerOrderReq",
    "CustomerOrder": "adyen:CustomerOrder",
    "CustomerOrderID": {
      "@id": "adyen:CustomerOrderID",
      "@type": "xsd:string"
    },
    "SaleReferenceID": {
      "@id": "adyen:SaleReferenceID",
      "@type": "xsd:string"
    },
    "OpenOrderState": {
      "@id": "adyen:OpenOrderState",
      "@type": "xsd:boolean"
    },
    "StartDate": {
      "@id": "adyen:StartDate",
      "@type": "xsd:dateTime"
    },
    "EndDate": {
      "@id": "adyen:EndDate",
      "@type": "xsd:dateTime"
    },
    "ForecastedAmount": {
      "@id": "adyen:ForecastedAmount",
      "@type": "xsd:decimal"
    },
    "CurrentAmount": {
      "@id": "adyen:CurrentAmount",
      "@type": "xsd:decimal"
    },
    "Currency": {
      "@id": "adyen:Currency",
      "@type": "xsd:string"
    },
    "AccessedBy": {
      "@id": "adyen:AccessedBy",
      "@type": "xsd:string"
    },
    "AdditionalInformation": {
      "@id": "adyen:AdditionalInformation",
      "@type": "xsd:string"
    }
  }
}