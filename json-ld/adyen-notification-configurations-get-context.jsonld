{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "GetNotificationConfigurationListResponse": "adyen:GetNotificationConfigurationListResponse",
    "GetNotificationConfigurationRequest": "adyen:GetNotificationConfigurationRequest",
    "GetNotificationConfigurationResponse": "adyen:GetNotificationConfigurationResponse",
    "configurations": {
      "@id": "adyen:configurations",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "invalidFields": {
      "@id": "adyen:invalidFields",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "pspReference": {
      "@id": "adyen:pspReference",
      "@type": "xsd:string"
    },
    "resultCode": {
      "@id": "adyen:resultCode",
      "@type": "xsd:string"
    },
    "notificationId": {
      "@id": "adyen:notificationId",
      "@type": "xsd:integer"
    },
    "configurationDetails": {
      "@id": "adyen:configurationDetails",
      "@type": "xsd:string"
    }
  }
}