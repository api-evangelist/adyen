{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "ViasPersonalData": "adyen:ViasPersonalData",
    "dateOfBirth": {
      "@id": "adyen:dateOfBirth",
      "@type": "xsd:string"
    },
    "documentData": {
      "@id": "adyen:documentData",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "nationality": {
      "@id": "adyen:nationality",
      "@type": "xsd:string"
    }
  }
}