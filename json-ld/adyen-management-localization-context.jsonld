{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "Localization": "adyen:Localization",
    "language": {
      "@id": "adyen:language",
      "@type": "xsd:string"
    },
    "secondaryLanguage": {
      "@id": "adyen:secondaryLanguage",
      "@type": "xsd:string"
    },
    "timezone": {
      "@id": "adyen:timezone",
      "@type": "xsd:string"
    }
  }
}