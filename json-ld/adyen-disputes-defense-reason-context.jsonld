{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "DefenseReason": "adyen:DefenseReason",
    "defenseDocumentTypes": {
      "@id": "adyen:defenseDocumentTypes",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "defenseReasonCode": {
      "@id": "adyen:defenseReasonCode",
      "@type": "xsd:string"
    },
    "satisfied": {
      "@id": "adyen:satisfied",
      "@type": "xsd:boolean"
    }
  }
}