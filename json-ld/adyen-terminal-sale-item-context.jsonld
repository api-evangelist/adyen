{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "SaleItemRebate": "adyen:SaleItemRebate",
    "SaleItem": "adyen:SaleItem",
    "ItemID": {
      "@id": "adyen:ItemID",
      "@type": "xsd:integer"
    },
    "ProductCode": {
      "@id": "adyen:ProductCode",
      "@type": "xsd:integer"
    },
    "EanUpc": {
      "@id": "adyen:EanUpc",
      "@type": "xsd:integer"
    },
    "UnitOfMeasure": {
      "@id": "adyen:UnitOfMeasure",
      "@type": "xsd:string"
    },
    "Quantity": {
      "@id": "adyen:Quantity",
      "@type": "xsd:string"
    },
    "ItemAmount": {
      "@id": "adyen:ItemAmount",
      "@type": "xsd:decimal"
    },
    "RebateLabel": {
      "@id": "adyen:RebateLabel",
      "@type": "xsd:string"
    },
    "UnitPrice": {
      "@id": "adyen:UnitPrice",
      "@type": "xsd:decimal"
    },
    "TaxCode": {
      "@id": "adyen:TaxCode",
      "@type": "xsd:integer"
    },
    "SaleChannel": {
      "@id": "adyen:SaleChannel",
      "@type": "xsd:integer"
    },
    "ProductLabel": {
      "@id": "adyen:ProductLabel",
      "@type": "xsd:string"
    },
    "AdditionalProductInfo": {
      "@id": "adyen:AdditionalProductInfo",
      "@type": "xsd:string"
    }
  }
}