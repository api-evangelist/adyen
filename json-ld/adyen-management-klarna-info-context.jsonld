    },
    "disputeEmail": {
      "@id": "adyen:disputeEmail",
      "@type": "xsd:string"
    },
    "region": {
      "@id": "adyen:region",
      "@type": "xsd:string"
    },
    "supportEmail": {
      "@id": "adyen:supportEmail",
      "@type": "xsd:string"
    }
  }
}