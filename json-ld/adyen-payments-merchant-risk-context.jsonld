{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "MerchantRiskIndicator": "adyen:MerchantRiskIndicator",
    "addressMatch": {
      "@id": "adyen:addressMatch",
      "@type": "xsd:boolean"
    },
    "deliveryAddressIndicator": {
      "@id": "adyen:deliveryAddressIndicator",
      "@type": "xsd:string"
    },
    "deliveryEmail": {
      "@id": "adyen:deliveryEmail",
      "@type": "xsd:string"
    },
    "deliveryEmailAddress": {
      "@id": "adyen:deliveryEmailAddress",
      "@type": "xsd:string"
    },
    "deliveryTimeframe": {
      "@id": "adyen:deliveryTimeframe",
      "@type": "xsd:string"
    },
    "giftCardAmount": {
      "@id": "adyen:giftCardAmount",
      "@type": "xsd:string"
    },
    "giftCardCount": {
      "@id": "adyen:giftCardCount",
      "@type": "xsd:integer"
    },
    "giftCardCurr": {
      "@id": "adyen:giftCardCurr",
      "@type": "xsd:string"
    },
    "preOrderDate": {
      "@id": "adyen:preOrderDate",
      "@type": "xsd:dateTime"
    },
    "preOrderPurchase": {
      "@id": "adyen:preOrderPurchase",
      "@type": "xsd:boolean"
    },
    "preOrderPurchaseInd": {
      "@id": "adyen:preOrderPurchaseInd",
      "@type": "xsd:string"
    },
    "reorderItems": {
      "@id": "adyen:reorderItems",
      "@type": "xsd:boolean"
    },
    "reorderItemsInd": {
      "@id": "adyen:reorderItemsInd",
      "@type": "xsd:string"
    },
    "shipIndicator": {
      "@id": "adyen:shipIndicator",
      "@type": "xsd:string"
    }
  }
}