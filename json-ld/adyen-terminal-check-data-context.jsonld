{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "CheckData": "adyen:CheckData",
    "BankID": {
      "@id": "adyen:BankID",
      "@type": "xsd:string"
    },
    "AccountNumber": {
      "@id": "adyen:AccountNumber",
      "@type": "xsd:string"
    },
    "CheckNumber": {
      "@id": "adyen:CheckNumber",
      "@type": "xsd:string"
    },
    "TrackData": {
      "@id": "adyen:TrackData",
      "@type": "xsd:string"
    },
    "CheckCardNumber": {
      "@id": "adyen:CheckCardNumber",
      "@type": "xsd:string"
    },
    "TypeCode": {
      "@id": "adyen:TypeCode",
      "@type": "xsd:string"
    },
    "Country": {
      "@id": "adyen:Country",
      "@type": "xsd:string"
    }
  }
}