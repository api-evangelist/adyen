{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "AdditionalSettingsResponse": "adyen:AdditionalSettingsResponse",
    "AdditionalSettings": "adyen:AdditionalSettings",
    "excludeEventCodes": {
      "@id": "adyen:excludeEventCodes",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "includeEventCodes": {
      "@id": "adyen:includeEventCodes",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "properties": {
      "@id": "adyen:properties",
      "@type": "@id"
    }
  }
}