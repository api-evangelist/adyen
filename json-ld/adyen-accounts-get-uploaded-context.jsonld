{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "GetUploadedDocumentsRequest": "adyen:GetUploadedDocumentsRequest",
    "GetUploadedDocumentsResponse": "adyen:GetUploadedDocumentsResponse",
    "accountHolderCode": {
      "@id": "adyen:accountHolderCode",
      "@type": "xsd:string"
    },
    "bankAccountUUID": {
      "@id": "adyen:bankAccountUUID",
      "@type": "xsd:string"
    },
    "shareholderCode": {
      "@id": "adyen:shareholderCode",
      "@type": "xsd:string"
    },
    "documentDetails": {
      "@id": "adyen:documentDetails",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "invalidFields": {
      "@id": "adyen:invalidFields",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "pspReference": {
      "@id": "adyen:pspReference",
      "@type": "xsd:string"
    },
    "resultCode": {
      "@id": "adyen:resultCode",
      "@type": "xsd:string"
    }
  }
}