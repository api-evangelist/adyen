{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "DeliveryAddress": "adyen:DeliveryAddress",
    "city": {
      "@id": "adyen:city",
      "@type": "xsd:string"
    },
    "country": {
      "@id": "adyen:country",
      "@type": "xsd:string"
    },
    "firstName": {
      "@id": "adyen:firstName",
      "@type": "xsd:string"
    },
    "houseNumberOrName": {
      "@id": "adyen:houseNumberOrName",
      "@type": "xsd:string"
    },
    "lastName": {
      "@id": "adyen:lastName",
      "@type": "xsd:string"
    },
    "postalCode": {
      "@id": "adyen:postalCode",
      "@type": "xsd:string"
    },
    "stateOrProvince": {
      "@id": "adyen:stateOrProvince",
      "@type": "xsd:string"
    },
    "street": {
      "@id": "adyen:street",
      "@type": "xsd:string"
    }
  }
}