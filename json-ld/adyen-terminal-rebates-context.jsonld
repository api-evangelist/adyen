{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "Rebates": "adyen:Rebates",
    "TotalRebate": {
      "@id": "adyen:TotalRebate",
      "@type": "xsd:decimal"
    },
    "RebateLabel": {
      "@id": "adyen:RebateLabel",
      "@type": "xsd:string"
    },
    "SaleItemRebate": {
      "@id": "adyen:SaleItemRebate",
      "@container": "@set",
      "@type": "xsd:string"
    }
  }
}