{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "CustomNotification": "adyen:CustomNotification",
    "amount": {
      "@id": "adyen:amount",
      "@type": "xsd:string"
    },
    "eventCode": {
      "@id": "adyen:eventCode",
      "@type": "xsd:string"
    },
    "eventDate": {
      "@id": "adyen:eventDate",
      "@type": "xsd:dateTime"
    },
    "merchantReference": {
      "@id": "adyen:merchantReference",
      "@type": "xsd:string"
    },
    "paymentMethod": {
      "@id": "adyen:paymentMethod",
      "@type": "xsd:string"
    },
    "reason": {
      "@id": "adyen:reason",
      "@type": "xsd:string"
    },
    "success": {
      "@id": "adyen:success",
      "@type": "xsd:boolean"
    }
  }
}