{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "Card": "adyen:Card",
    "cvc": {
      "@id": "adyen:cvc",
      "@type": "xsd:string"
    },
    "expiryMonth": {
      "@id": "adyen:expiryMonth",
      "@type": "xsd:string"
    },
    "expiryYear": {
      "@id": "adyen:expiryYear",
      "@type": "xsd:string"
    },
    "holderName": {
      "@id": "adyen:holderName",
      "@type": "xsd:string"
    },
    "issueNumber": {
      "@id": "adyen:issueNumber",
      "@type": "xsd:string"
    },
    "number": {
      "@id": "adyen:number",
      "@type": "xsd:string"
    },
    "startMonth": {
      "@id": "adyen:startMonth",
      "@type": "xsd:string"
    },
    "startYear": {
      "@id": "adyen:startYear",
      "@type": "xsd:string"
    }
  }
}