{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "FraudResult": "adyen:FraudResult",
    "accountScore": {
      "@id": "adyen:accountScore",
      "@type": "xsd:integer"
    },
    "results": {
      "@id": "adyen:results",
      "@container": "@set",
      "@type": "xsd:string"
    }
  }
}