{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "Split": "adyen:Split",
    "account": {
      "@id": "adyen:account",
      "@type": "xsd:string"
    },
    "amount": {
      "@id": "adyen:amount",
      "@type": "xsd:string"
    },
    "description": "schema:description",
    "reference": {
      "@id": "adyen:reference",
      "@type": "xsd:string"
    },
    "type": {
      "@id": "adyen:type",
      "@type": "xsd:string"
    }
  }
}