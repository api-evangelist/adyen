    "contentType": {
      "@id": "adyen:contentType",
      "@type": "xsd:string"
    },
    "filename": {
      "@id": "adyen:filename",
      "@type": "xsd:string"
    },
    "pageName": {
      "@id": "adyen:pageName",
      "@type": "xsd:string"
    },
    "pageType": {
      "@id": "adyen:pageType",
      "@type": "xsd:string"
    }
  }
}