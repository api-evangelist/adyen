{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "PayoutRequest": "adyen:PayoutRequest",
    "amount": {
      "@id": "adyen:amount",
      "@type": "xsd:string"
    },
    "billingAddress": {
      "@id": "adyen:billingAddress",
      "@type": "xsd:string"
    },
    "card": {
      "@id": "adyen:card",
      "@type": "xsd:string"
    },
    "fraudOffset": {
      "@id": "adyen:fraudOffset",
      "@type": "xsd:integer"
    },
    "fundSource": {
      "@id": "adyen:fundSource",
      "@type": "xsd:string"
    },
    "merchantAccount": {
      "@id": "adyen:merchantAccount",
      "@type": "xsd:string"
    },
    "recurring": {
      "@id": "adyen:recurring",
      "@type": "xsd:string"
    },
    "reference": {
      "@id": "adyen:reference",
      "@type": "xsd:string"
    },
    "selectedRecurringDetailReference": {
      "@id": "adyen:selectedRecurringDetailReference",
      "@type": "xsd:string"
    },
    "shopperEmail": {
      "@id": "adyen:shopperEmail",
      "@type": "xsd:string"
    },
    "shopperInteraction": {
      "@id": "adyen:shopperInteraction",
      "@type": "xsd:string"
    },
    "shopperName": {
      "@id": "adyen:shopperName",
      "@type": "xsd:string"
    },
    "shopperReference": {
      "@id": "adyen:shopperReference",
      "@type": "xsd:string"
    },
    "telephoneNumber": {
      "@id": "adyen:telephoneNumber",
      "@type": "xsd:string"
    }
  }
}