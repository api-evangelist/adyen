{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "Merchant": "adyen:Merchant",
    "Links": {
      "@id": "adyen:_links",
      "@type": "xsd:string"
    },
    "captureDelay": {
      "@id": "adyen:captureDelay",
      "@type": "xsd:string"
    },
    "companyId": {
      "@id": "adyen:companyId",
      "@type": "xsd:string"
    },
    "dataCenters": {
      "@id": "adyen:dataCenters",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "defaultShopperInteraction": {
      "@id": "adyen:defaultShopperInteraction",
      "@type": "xsd:string"
    },
    "description": "schema:description",
    "id": {
      "@id": "adyen:id",
      "@type": "xsd:string"
    },
    "merchantCity": {
      "@id": "adyen:merchantCity",
      "@type": "xsd:string"
    },
    "name": "schema:name",
    "pricingPlan": {
      "@id": "adyen:pricingPlan",
      "@type": "xsd:string"
    },
    "primarySettlementCurrency": {
      "@id": "adyen:primarySettlementCurrency",
      "@type": "xsd:string"
    },
    "reference": {
      "@id": "adyen:reference",
      "@type": "xsd:string"
    },
    "shopWebAddress": {
      "@id": "adyen:shopWebAddress",
      "@type": "xsd:string"
    },
    "status": {
      "@id": "adyen:status",
      "@type": "xsd:string"
    }
  }
}