{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "AccountSupportingEntityCapability": "adyen:AccountSupportingEntityCapability",
    "allowed": {
      "@id": "adyen:allowed",
      "@type": "xsd:boolean"
    },
    "allowedLevel": {
      "@id": "adyen:allowedLevel",
      "@type": "xsd:string"
    },
    "enabled": {
      "@id": "adyen:enabled",
      "@type": "xsd:boolean"
    },
    "id": {
      "@id": "adyen:id",
      "@type": "xsd:string"
    },
    "requested": {
      "@id": "adyen:requested",
      "@type": "xsd:boolean"
    },
    "requestedLevel": {
      "@id": "adyen:requestedLevel",
      "@type": "xsd:string"
    },
    "verificationStatus": {
      "@id": "adyen:verificationStatus",
      "@type": "xsd:string"
    }
  }
}