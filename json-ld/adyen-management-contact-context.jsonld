{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "Contact": "adyen:Contact",
    "email": "schema:email",
    "firstName": {
      "@id": "adyen:firstName",
      "@type": "xsd:string"
    },
    "infix": {
      "@id": "adyen:infix",
      "@type": "xsd:string"
    },
    "lastName": {
      "@id": "adyen:lastName",
      "@type": "xsd:string"
    },
    "phoneNumber": {
      "@id": "adyen:phoneNumber",
      "@type": "xsd:string"
    }
  }
}