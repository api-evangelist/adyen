{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "VerificationDeadline": "adyen:VerificationDeadline",
    "capabilities": {
      "@id": "adyen:capabilities",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "entityIds": {
      "@id": "adyen:entityIds",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "expiresAt": {
      "@id": "adyen:expiresAt",
      "@type": "xsd:dateTime"
    }
  }
}