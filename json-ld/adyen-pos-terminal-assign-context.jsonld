{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "AssignTerminalsRequest": "adyen:AssignTerminalsRequest",
    "AssignTerminalsResponse": "adyen:AssignTerminalsResponse",
    "companyAccount": {
      "@id": "adyen:companyAccount",
      "@type": "xsd:string"
    },
    "merchantAccount": {
      "@id": "adyen:merchantAccount",
      "@type": "xsd:string"
    },
    "merchantInventory": {
      "@id": "adyen:merchantInventory",
      "@type": "xsd:boolean"
    },
    "store": {
      "@id": "adyen:store",
      "@type": "xsd:string"
    },
    "terminals": {
      "@id": "adyen:terminals",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "results": {
      "@id": "adyen:results",
      "@type": "@id"
    }
  }
}