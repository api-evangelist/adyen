{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "Company": "adyen:Company",
    "homepage": {
      "@id": "adyen:homepage",
      "@type": "xsd:string"
    },
    "name": "schema:name",
    "registrationNumber": {
      "@id": "adyen:registrationNumber",
      "@type": "xsd:string"
    },
    "registryLocation": {
      "@id": "adyen:registryLocation",
      "@type": "xsd:string"
    },
    "taxId": {
      "@id": "adyen:taxId",
      "@type": "xsd:string"
    },
    "type": {
      "@id": "adyen:type",
      "@type": "xsd:string"
    }
  }
}