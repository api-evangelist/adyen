{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "ReceiptOptions": "adyen:ReceiptOptions",
    "logo": {
      "@id": "adyen:logo",
      "@type": "xsd:string"
    },
    "promptBeforePrinting": {
      "@id": "adyen:promptBeforePrinting",
      "@type": "xsd:boolean"
    },
    "qrCodeData": {
      "@id": "adyen:qrCodeData",
      "@type": "xsd:string"
    }
  }
}