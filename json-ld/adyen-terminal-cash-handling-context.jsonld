{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "CashHandlingDevice": "adyen:CashHandlingDevice",
    "CashHandlingOKFlag": {
      "@id": "adyen:CashHandlingOKFlag",
      "@type": "xsd:boolean"
    },
    "Currency": {
      "@id": "adyen:Currency",
      "@type": "xsd:string"
    },
    "CoinsOrBills": {
      "@id": "adyen:CoinsOrBills",
      "@container": "@set",
      "@type": "xsd:string"
    }
  }
}