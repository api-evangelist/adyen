    },
    "shopperEmail": {
      "@id": "adyen:shopperEmail",
      "@type": "xsd:string"
    },
    "shopperName": {
      "@id": "adyen:shopperName",
      "@type": "xsd:string"
    },
    "shopperReference": {
      "@id": "adyen:shopperReference",
      "@type": "xsd:string"
    },
    "storedPaymentMethodId": {
      "@id": "adyen:storedPaymentMethodId",
      "@type": "xsd:string"
    },
    "subMerchant": {
      "@id": "adyen:subMerchant",
      "@type": "xsd:string"
    },
    "telephoneNumber": {
      "@id": "adyen:telephoneNumber",
      "@type": "xsd:string"
    },
    "walletIdentifier": {
      "@id": "adyen:walletIdentifier",
      "@type": "xsd:string"
    },
    "walletOwnerTaxId": {
      "@id": "adyen:walletOwnerTaxId",
