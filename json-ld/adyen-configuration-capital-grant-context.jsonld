{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "CapitalGrantAccount": "adyen:CapitalGrantAccount",
    "balances": {
      "@id": "adyen:balances",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "fundingBalanceAccountId": {
      "@id": "adyen:fundingBalanceAccountId",
      "@type": "xsd:string"
    },
    "id": {
      "@id": "adyen:id",
      "@type": "xsd:string"
    },
    "limits": {
      "@id": "adyen:limits",
      "@container": "@set",
      "@type": "xsd:string"
    }
  }
}