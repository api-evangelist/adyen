{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "Address": "adyen:Address",
    "city": {
      "@id": "adyen:city",
      "@type": "xsd:string"
    },
    "companyName": {
      "@id": "adyen:companyName",
      "@type": "xsd:string"
    },
    "country": {
      "@id": "adyen:country",
      "@type": "xsd:string"
    },
    "postalCode": {
      "@id": "adyen:postalCode",
      "@type": "xsd:string"
    },
    "stateOrProvince": {
      "@id": "adyen:stateOrProvince",
      "@type": "xsd:string"
    },
    "streetAddress": {
      "@id": "adyen:streetAddress",
      "@type": "xsd:string"
    },
    "streetAddress2": {
      "@id": "adyen:streetAddress2",
      "@type": "xsd:string"
    }
  }
}