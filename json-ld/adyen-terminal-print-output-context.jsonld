{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "PrintOutput": "adyen:PrintOutput",
    "DocumentQualifier": {
      "@id": "adyen:DocumentQualifier",
      "@type": "xsd:string"
    },
    "ResponseMode": {
      "@id": "adyen:ResponseMode",
      "@type": "xsd:string"
    },
    "IntegratedPrintFlag": {
      "@id": "adyen:IntegratedPrintFlag",
      "@type": "xsd:boolean"
    },
    "RequiredSignatureFlag": {
      "@id": "adyen:RequiredSignatureFlag",
      "@type": "xsd:boolean"
    },
    "OutputContent": {
      "@id": "adyen:OutputContent",
      "@type": "xsd:string"
    }
  }
}