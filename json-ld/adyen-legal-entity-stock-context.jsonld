{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "StockData": "adyen:StockData",
    "marketIdentifier": {
      "@id": "adyen:marketIdentifier",
      "@type": "xsd:string"
    },
    "stockNumber": {
      "@id": "adyen:stockNumber",
      "@type": "xsd:string"
    },
    "tickerSymbol": {
      "@id": "adyen:tickerSymbol",
      "@type": "xsd:string"
    }
  }
}