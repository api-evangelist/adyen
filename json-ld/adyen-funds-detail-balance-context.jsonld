{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "DetailBalance": "adyen:DetailBalance",
    "balance": {
      "@id": "adyen:balance",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "onHoldBalance": {
      "@id": "adyen:onHoldBalance",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "pendingBalance": {
      "@id": "adyen:pendingBalance",
      "@container": "@set",
      "@type": "xsd:string"
    }
  }
}