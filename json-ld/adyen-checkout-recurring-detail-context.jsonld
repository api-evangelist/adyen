{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "RecurringDetail": "adyen:RecurringDetail",
    "brand": {
      "@id": "adyen:brand",
      "@type": "xsd:string"
    },
    "brands": {
      "@id": "adyen:brands",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "configuration": {
      "@id": "adyen:configuration",
      "@type": "@id"
    },
    "fundingSource": {
      "@id": "adyen:fundingSource",
      "@type": "xsd:string"
    },
    "group": {
      "@id": "adyen:group",
      "@type": "xsd:string"
    },
    "inputDetails": {
      "@id": "adyen:inputDetails",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "issuers": {
      "@id": "adyen:issuers",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "name": "schema:name",
    "recurringDetailReference": {
      "@id": "adyen:recurringDetailReference",
      "@type": "xsd:string"
    },
    "storedDetails": {
      "@id": "adyen:storedDetails",
      "@type": "xsd:string"
    },
    "type": {
      "@id": "adyen:type",
      "@type": "xsd:string"
    }
  }
}