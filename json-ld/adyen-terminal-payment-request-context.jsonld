{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "PaymentRequest": "adyen:PaymentRequest",
    "SaleData": {
      "@id": "adyen:SaleData",
      "@type": "xsd:string"
    },
    "PaymentTransaction": {
      "@id": "adyen:PaymentTransaction",
      "@type": "xsd:string"
    },
    "PaymentData": {
      "@id": "adyen:PaymentData",
      "@type": "xsd:string"
    },
    "LoyaltyData": {
      "@id": "adyen:LoyaltyData",
      "@container": "@set",
      "@type": "xsd:string"
    }
  }
}