{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "AccountEvent": "adyen:AccountEvent",
    "event": {
      "@id": "adyen:event",
      "@type": "xsd:string"
    },
    "executionDate": {
      "@id": "adyen:executionDate",
      "@type": "xsd:dateTime"
    },
    "reason": {
      "@id": "adyen:reason",
      "@type": "xsd:string"
    }
  }
}