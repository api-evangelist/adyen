{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "ScheduleAccountUpdaterRequest": "adyen:ScheduleAccountUpdaterRequest",
    "ScheduleAccountUpdaterResult": "adyen:ScheduleAccountUpdaterResult",
    "additionalData": {
      "@id": "adyen:additionalData",
      "@type": "@id"
    },
    "card": {
      "@id": "adyen:card",
      "@type": "xsd:string"
    },
    "merchantAccount": {
      "@id": "adyen:merchantAccount",
      "@type": "xsd:string"
    },
    "reference": {
      "@id": "adyen:reference",
      "@type": "xsd:string"
    },
    "selectedRecurringDetailReference": {
      "@id": "adyen:selectedRecurringDetailReference",
      "@type": "xsd:string"
    },
    "shopperReference": {
      "@id": "adyen:shopperReference",
      "@type": "xsd:string"
    },
    "pspReference": {
      "@id": "adyen:pspReference",
      "@type": "xsd:string"
    },
    "result": {
      "@id": "adyen:result",
      "@type": "xsd:string"
    }
  }
}