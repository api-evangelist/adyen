{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "PaginationLinks": "adyen:PaginationLinks",
    "first": {
      "@id": "adyen:first",
      "@type": "xsd:string"
    },
    "last": {
      "@id": "adyen:last",
      "@type": "xsd:string"
    },
    "next": {
      "@id": "adyen:next",
      "@type": "xsd:string"
    },
    "prev": {
      "@id": "adyen:prev",
      "@type": "xsd:string"
    },
    "self": {
      "@id": "adyen:self",
      "@type": "xsd:string"
    }
  }
}