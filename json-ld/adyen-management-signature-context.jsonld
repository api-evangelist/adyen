{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "Signature": "adyen:Signature",
    "askSignatureOnScreen": {
      "@id": "adyen:askSignatureOnScreen",
      "@type": "xsd:boolean"
    },
    "deviceName": {
      "@id": "adyen:deviceName",
      "@type": "xsd:string"
    },
    "deviceSlogan": {
      "@id": "adyen:deviceSlogan",
      "@type": "xsd:string"
    },
    "skipSignature": {
      "@id": "adyen:skipSignature",
      "@type": "xsd:boolean"
    }
  }
}