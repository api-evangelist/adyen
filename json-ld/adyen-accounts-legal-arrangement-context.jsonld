    },
    "legalArrangementReference": {
      "@id": "adyen:legalArrangementReference",
      "@type": "xsd:string"
    },
    "legalForm": {
      "@id": "adyen:legalForm",
      "@type": "xsd:string"
    },
    "name": "schema:name",
    "registrationNumber": {
      "@id": "adyen:registrationNumber",
      "@type": "xsd:string"
    },
    "taxNumber": {
      "@id": "adyen:taxNumber",
      "@type": "xsd:string"
    },
    "type": {
      "@id": "adyen:type",
      "@type": "xsd:string"
    },
    "businessDetails": {
      "@id": "adyen:businessDetails",
      "@type": "xsd:string"
    },
    "email": "schema:email",
    "fullPhoneNumber": {
      "@id": "adyen:fullPhoneNumber",
      "@type": "xsd:string"
    },
    "individualDetails": {
      "@id": "adyen:individualDetails",
      "@type": "xsd:string"
    },
    "legalArrangementEntityCode": {
      "@id": "adyen:legalArrangementEntityCode",
      "@type": "xsd:string"
    },
    "legalArrangementEntityReference": {
      "@id": "adyen:legalArrangementEntityReference",
      "@type": "xsd:string"
    },
    "legalArrangementMembers": {
      "@id": "adyen:legalArrangementMembers",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "legalEntityType": {
      "@id": "adyen:legalEntityType",
      "@type": "xsd:string"
    },
    "phoneNumber": {
      "@id": "adyen:phoneNumber",
      "@type": "xsd:string"
    },
    "webAddress": {
      "@id": "adyen:webAddress",
      "@type": "xsd:string"
    },
    "legalArrangementEntityCodes": {
      "@id": "adyen:legalArrangementEntityCodes",
