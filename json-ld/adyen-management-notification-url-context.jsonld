{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "NotificationUrl": "adyen:NotificationUrl",
    "localUrls": {
      "@id": "adyen:localUrls",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "publicUrls": {
      "@id": "adyen:publicUrls",
      "@container": "@set",
      "@type": "xsd:string"
    }
  }
}