{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "CreateOrderRequest": "adyen:CreateOrderRequest",
    "CreateOrderResponse": "adyen:CreateOrderResponse",
    "amount": {
      "@id": "adyen:amount",
      "@type": "xsd:string"
    },
    "expiresAt": {
      "@id": "adyen:expiresAt",
      "@type": "xsd:string"
    },
    "merchantAccount": {
      "@id": "adyen:merchantAccount",
      "@type": "xsd:string"
    },
    "reference": {
      "@id": "adyen:reference",
      "@type": "xsd:string"
    },
    "additionalData": {
      "@id": "adyen:additionalData",
      "@type": "@id"
    },
    "fraudResult": {
      "@id": "adyen:fraudResult",
      "@type": "xsd:string"
    },
    "orderData": {
      "@id": "adyen:orderData",
      "@type": "xsd:string"
    },
    "pspReference": {
      "@id": "adyen:pspReference",
      "@type": "xsd:string"
    },
    "refusalReason": {
      "@id": "adyen:refusalReason",
      "@type": "xsd:string"
    },
    "remainingAmount": {
      "@id": "adyen:remainingAmount",
      "@type": "xsd:string"
    },
    "resultCode": {
      "@id": "adyen:resultCode",
      "@type": "xsd:string"
    }
  }
}