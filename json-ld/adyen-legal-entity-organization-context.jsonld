{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "Organization": "adyen:Organization",
    "dateOfIncorporation": {
      "@id": "adyen:dateOfIncorporation",
      "@type": "xsd:string"
    },
    "description": "schema:description",
    "doingBusinessAs": {
      "@id": "adyen:doingBusinessAs",
      "@type": "xsd:string"
    },
    "email": "schema:email",
    "legalName": {
      "@id": "adyen:legalName",
      "@type": "xsd:string"
    },
    "phone": {
      "@id": "adyen:phone",
      "@type": "xsd:string"
    },
    "principalPlaceOfBusiness": {
      "@id": "adyen:principalPlaceOfBusiness",
      "@type": "xsd:string"
    },
    "registeredAddress": {
      "@id": "adyen:registeredAddress",
      "@type": "xsd:string"
    },
    "registrationNumber": {
      "@id": "adyen:registrationNumber",
      "@type": "xsd:string"
    },
    "stockData": {
      "@id": "adyen:stockData",
      "@type": "xsd:string"
    },
    "taxInformation": {
      "@id": "adyen:taxInformation",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "taxReportingClassification": {
      "@id": "adyen:taxReportingClassification",
      "@type": "xsd:string"
    },
    "type": {
      "@id": "adyen:type",
      "@type": "xsd:string"
    },
    "vatAbsenceReason": {
      "@id": "adyen:vatAbsenceReason",
      "@type": "xsd:string"
    },
    "vatNumber": {
      "@id": "adyen:vatNumber",
      "@type": "xsd:string"
    },
    "webData": {
      "@id": "adyen:webData",
      "@type": "xsd:string"
    }
  }
}