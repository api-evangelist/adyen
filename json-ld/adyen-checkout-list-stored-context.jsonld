{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "ListStoredPaymentMethodsResponse": "adyen:ListStoredPaymentMethodsResponse",
    "merchantAccount": {
      "@id": "adyen:merchantAccount",
      "@type": "xsd:string"
    },
    "shopperReference": {
      "@id": "adyen:shopperReference",
      "@type": "xsd:string"
    },
    "storedPaymentMethods": {
      "@id": "adyen:storedPaymentMethods",
      "@container": "@set",
      "@type": "xsd:string"
    }
  }
}