{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "ExternalTerminalAction": "adyen:ExternalTerminalAction",
    "actionType": {
      "@id": "adyen:actionType",
      "@type": "xsd:string"
    },
    "config": {
      "@id": "adyen:config",
      "@type": "xsd:string"
    },
    "confirmedAt": {
      "@id": "adyen:confirmedAt",
      "@type": "xsd:dateTime"
    },
    "id": {
      "@id": "adyen:id",
      "@type": "xsd:string"
    },
    "result": {
      "@id": "adyen:result",
      "@type": "xsd:string"
    },
    "scheduledAt": {
      "@id": "adyen:scheduledAt",
      "@type": "xsd:dateTime"
    },
    "status": {
      "@id": "adyen:status",
      "@type": "xsd:string"
    },
    "terminalId": {
      "@id": "adyen:terminalId",
      "@type": "xsd:string"
    }
  }
}