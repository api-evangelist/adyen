{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "StandalonePaymentCancelRequest": "adyen:StandalonePaymentCancelRequest",
    "StandalonePaymentCancelResponse": "adyen:StandalonePaymentCancelResponse",
    "applicationInfo": {
      "@id": "adyen:applicationInfo",
      "@type": "xsd:string"
    },
    "merchantAccount": {
      "@id": "adyen:merchantAccount",
      "@type": "xsd:string"
    },
    "paymentReference": {
      "@id": "adyen:paymentReference",
      "@type": "xsd:string"
    },
    "reference": {
      "@id": "adyen:reference",
      "@type": "xsd:string"
    },
    "pspReference": {
      "@id": "adyen:pspReference",
      "@type": "xsd:string"
    },
    "status": {
      "@id": "adyen:status",
      "@type": "xsd:string"
    }
  }
}