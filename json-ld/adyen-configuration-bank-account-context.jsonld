{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "BankAccountIdentificationTypeRequirement": "adyen:BankAccountIdentificationTypeRequirement",
    "BankAccountIdentificationValidationRequest": "adyen:BankAccountIdentificationValidationRequest",
    "BankAccountModel": "adyen:BankAccountModel",
    "BankAccount": "adyen:BankAccount",
    "bankAccountIdentificationTypes": {
      "@id": "adyen:bankAccountIdentificationTypes",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "description": "schema:description",
    "type": {
      "@id": "adyen:type",
      "@type": "xsd:string"
    },
    "accountIdentification": {
      "@id": "adyen:accountIdentification",
      "@type": "xsd:string"
    },
    "formFactor": {
      "@id": "adyen:formFactor",
      "@type": "xsd:string"
    }
  }
}