{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "VerificationDeadline": "adyen:VerificationDeadline",
    "VerificationError-recursive": "adyen:VerificationError-recursive",
    "VerificationError": "adyen:VerificationError",
    "VerificationErrors": "adyen:VerificationErrors",
    "capabilities": {
      "@id": "adyen:capabilities",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "entityIds": {
      "@id": "adyen:entityIds",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "expiresAt": {
      "@id": "adyen:expiresAt",
      "@type": "xsd:dateTime"
    },
    "code": {
      "@id": "adyen:code",
      "@type": "xsd:string"
    },
    "message": {
      "@id": "adyen:message",
      "@type": "xsd:string"
    },
    "type": {
      "@id": "adyen:type",
      "@type": "xsd:string"
    },
    "remediatingActions": {
      "@id": "adyen:remediatingActions",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "subErrors": {
      "@id": "adyen:subErrors",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "problems": {
      "@id": "adyen:problems",
      "@container": "@set",
      "@type": "xsd:string"
    }
  }
}