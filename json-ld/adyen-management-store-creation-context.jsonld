{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "StoreCreationRequest": "adyen:StoreCreationRequest",
    "StoreCreationWithMerchantCodeRequest": "adyen:StoreCreationWithMerchantCodeRequest",
    "address": {
      "@id": "adyen:address",
      "@type": "xsd:string"
    },
    "businessLineIds": {
      "@id": "adyen:businessLineIds",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "description": "schema:description",
    "externalReferenceId": {
      "@id": "adyen:externalReferenceId",
      "@type": "xsd:string"
    },
    "phoneNumber": {
      "@id": "adyen:phoneNumber",
      "@type": "xsd:string"
    },
    "reference": {
      "@id": "adyen:reference",
      "@type": "xsd:string"
    },
    "shopperStatement": {
      "@id": "adyen:shopperStatement",
      "@type": "xsd:string"
    },
    "splitConfiguration": {
      "@id": "adyen:splitConfiguration",
      "@type": "xsd:string"
    },
    "merchantId": {
      "@id": "adyen:merchantId",
      "@type": "xsd:string"
    }
  }
}