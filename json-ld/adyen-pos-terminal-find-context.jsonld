{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "FindTerminalRequest": "adyen:FindTerminalRequest",
    "FindTerminalResponse": "adyen:FindTerminalResponse",
    "terminal": {
      "@id": "adyen:terminal",
      "@type": "xsd:string"
    },
    "companyAccount": {
      "@id": "adyen:companyAccount",
      "@type": "xsd:string"
    },
    "merchantAccount": {
      "@id": "adyen:merchantAccount",
      "@type": "xsd:string"
    },
    "merchantInventory": {
      "@id": "adyen:merchantInventory",
      "@type": "xsd:boolean"
    },
    "store": {
      "@id": "adyen:store",
      "@type": "xsd:string"
    }
  }
}