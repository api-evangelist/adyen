{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "TestWebhookRequest": "adyen:TestWebhookRequest",
    "TestWebhookResponse": "adyen:TestWebhookResponse",
    "notification": {
      "@id": "adyen:notification",
      "@type": "xsd:string"
    },
    "types": {
      "@id": "adyen:types",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "data": {
      "@id": "adyen:data",
      "@container": "@set",
      "@type": "xsd:string"
    }
  }
}