{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "LoyaltyTotals": "adyen:LoyaltyTotals",
    "TransactionType": {
      "@id": "adyen:TransactionType",
      "@type": "xsd:string"
    },
    "TransactionCount": {
      "@id": "adyen:TransactionCount",
      "@type": "xsd:integer"
    },
    "TransactionAmount": {
      "@id": "adyen:TransactionAmount",
      "@type": "xsd:decimal"
    }
  }
}