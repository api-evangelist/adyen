{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "PaymentAmountUpdateRequest": "adyen:PaymentAmountUpdateRequest",
    "PaymentAmountUpdateResponse": "adyen:PaymentAmountUpdateResponse",
    "amount": {
      "@id": "adyen:amount",
      "@type": "xsd:string"
    },
    "applicationInfo": {
      "@id": "adyen:applicationInfo",
      "@type": "xsd:string"
    },
    "industryUsage": {
      "@id": "adyen:industryUsage",
      "@type": "xsd:string"
    },
    "lineItems": {
      "@id": "adyen:lineItems",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "merchantAccount": {
      "@id": "adyen:merchantAccount",
      "@type": "xsd:string"
    },
    "reference": {
      "@id": "adyen:reference",
      "@type": "xsd:string"
    },
    "splits": {
      "@id": "adyen:splits",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "paymentPspReference": {
      "@id": "adyen:paymentPspReference",
      "@type": "xsd:string"
    },
    "pspReference": {
      "@id": "adyen:pspReference",
      "@type": "xsd:string"
    },
    "status": {
      "@id": "adyen:status",
      "@type": "xsd:string"
    }
  }
}