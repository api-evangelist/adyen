{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "Balance": "adyen:Balance",
    "available": {
      "@id": "adyen:available",
      "@type": "xsd:integer"
    },
    "balance": {
      "@id": "adyen:balance",
      "@type": "xsd:integer"
    },
    "currency": {
      "@id": "adyen:currency",
      "@type": "xsd:string"
    },
    "pending": {
      "@id": "adyen:pending",
      "@type": "xsd:integer"
    },
    "reserved": {
      "@id": "adyen:reserved",
      "@type": "xsd:integer"
    }
  }
}