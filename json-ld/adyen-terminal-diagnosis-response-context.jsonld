      "@id": "adyen:Response",
      "@type": "xsd:string"
    },
    "LoggedSaleID": {
      "@id": "adyen:LoggedSaleID",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "POIStatus": {
      "@id": "adyen:POIStatus",
      "@type": "xsd:string"
    },
    "HostStatus": {
      "@id": "adyen:HostStatus",
      "@container": "@set",
      "@type": "xsd:string"
    }
  }
}