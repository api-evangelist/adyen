{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "OutputText": "adyen:OutputText",
    "Text": {
      "@id": "adyen:Text",
      "@type": "xsd:string"
    },
    "CharacterSet": {
      "@id": "adyen:CharacterSet",
      "@type": "xsd:integer"
    },
    "Font": {
      "@id": "adyen:Font",
      "@type": "xsd:string"
    },
    "StartRow": {
      "@id": "adyen:StartRow",
      "@type": "xsd:integer"
    },
    "StartColumn": {
      "@id": "adyen:StartColumn",
      "@type": "xsd:integer"
    },
    "Color": {
      "@id": "adyen:Color",
      "@type": "xsd:string"
    },
    "CharacterWidth": {
      "@id": "adyen:CharacterWidth",
      "@type": "xsd:string"
    },
    "CharacterHeight": {
      "@id": "adyen:CharacterHeight",
      "@type": "xsd:string"
    },
    "CharacterStyle": {
      "@id": "adyen:CharacterStyle",
      "@type": "xsd:string"
    },
    "Alignment": {
      "@id": "adyen:Alignment",
      "@type": "xsd:string"
    },
    "EndOfLineFlag": {
      "@id": "adyen:EndOfLineFlag",
      "@type": "xsd:boolean"
    }
  }
}