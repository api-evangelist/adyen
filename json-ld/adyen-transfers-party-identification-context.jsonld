{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "PartyIdentification": "adyen:PartyIdentification",
    "address": {
      "@id": "adyen:address",
      "@type": "xsd:string"
    },
    "dateOfBirth": {
      "@id": "adyen:dateOfBirth",
      "@type": "xsd:date"
    },
    "firstName": {
      "@id": "adyen:firstName",
      "@type": "xsd:string"
    },
    "fullName": {
      "@id": "adyen:fullName",
      "@type": "xsd:string"
    },
    "lastName": {
      "@id": "adyen:lastName",
      "@type": "xsd:string"
    },
    "reference": {
      "@id": "adyen:reference",
      "@type": "xsd:string"
    },
    "type": {
      "@id": "adyen:type",
      "@type": "xsd:string"
    }
  }
}