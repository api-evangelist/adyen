{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "VoidPendingRefundRequest": "adyen:VoidPendingRefundRequest",
    "additionalData": {
      "@id": "adyen:additionalData",
      "@type": "@id"
    },
    "merchantAccount": {
      "@id": "adyen:merchantAccount",
      "@type": "xsd:string"
    },
    "modificationAmount": {
      "@id": "adyen:modificationAmount",
      "@type": "xsd:string"
    },
    "mpiData": {
      "@id": "adyen:mpiData",
      "@type": "xsd:string"
    },
    "originalMerchantReference": {
      "@id": "adyen:originalMerchantReference",
      "@type": "xsd:string"
    },
    "originalReference": {
      "@id": "adyen:originalReference",
      "@type": "xsd:string"
    },
    "platformChargebackLogic": {
      "@id": "adyen:platformChargebackLogic",
      "@type": "xsd:string"
    },
    "reference": {
      "@id": "adyen:reference",
      "@type": "xsd:string"
    },
    "splits": {
      "@id": "adyen:splits",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "tenderReference": {
      "@id": "adyen:tenderReference",
      "@type": "xsd:string"
    },
    "uniqueTerminalId": {
      "@id": "adyen:uniqueTerminalId",
      "@type": "xsd:string"
    }
  }
}