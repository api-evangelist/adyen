{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "TermsOfServiceAcceptanceInfo": "adyen:TermsOfServiceAcceptanceInfo",
    "acceptedBy": {
      "@id": "adyen:acceptedBy",
      "@type": "xsd:string"
    },
    "acceptedFor": {
      "@id": "adyen:acceptedFor",
      "@type": "xsd:string"
    },
    "createdAt": {
      "@id": "adyen:createdAt",
      "@type": "xsd:dateTime"
    },
    "id": {
      "@id": "adyen:id",
      "@type": "xsd:string"
    },
    "type": {
      "@id": "adyen:type",
      "@type": "xsd:string"
    }
  }
}