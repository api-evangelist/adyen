{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "SensitiveCardData": "adyen:SensitiveCardData",
    "PAN": {
      "@id": "adyen:PAN",
      "@type": "xsd:integer"
    },
    "CardSeqNumb": {
      "@id": "adyen:CardSeqNumb",
      "@type": "xsd:integer"
    },
    "ExpiryDate": {
      "@id": "adyen:ExpiryDate",
      "@type": "xsd:integer"
    },
    "TrackData": {
      "@id": "adyen:TrackData",
      "@container": "@set",
      "@type": "xsd:string"
    }
  }
}