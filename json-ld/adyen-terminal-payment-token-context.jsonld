{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "PaymentToken": "adyen:PaymentToken",
    "TokenRequestedType": {
      "@id": "adyen:TokenRequestedType",
      "@type": "xsd:string"
    },
    "TokenValue": {
      "@id": "adyen:TokenValue",
      "@type": "xsd:string"
    },
    "ExpiryDateTime": {
      "@id": "adyen:ExpiryDateTime",
      "@type": "xsd:dateTime"
    }
  }
}