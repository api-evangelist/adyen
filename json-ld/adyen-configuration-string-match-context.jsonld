{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "StringMatch": "adyen:StringMatch",
    "operation": {
      "@id": "adyen:operation",
      "@type": "xsd:string"
    },
    "value": {
      "@id": "adyen:value",
      "@type": "xsd:string"
    }
  }
}