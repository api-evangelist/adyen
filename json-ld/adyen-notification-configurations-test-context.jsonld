{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "TestNotificationConfigurationRequest": "adyen:TestNotificationConfigurationRequest",
    "TestNotificationConfigurationResponse": "adyen:TestNotificationConfigurationResponse",
    "eventTypes": {
      "@id": "adyen:eventTypes",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "notificationId": {
      "@id": "adyen:notificationId",
      "@type": "xsd:integer"
    },
    "errorMessages": {
      "@id": "adyen:errorMessages",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "exchangeMessages": {
      "@id": "adyen:exchangeMessages",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "invalidFields": {
      "@id": "adyen:invalidFields",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "okMessages": {
      "@id": "adyen:okMessages",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "pspReference": {
      "@id": "adyen:pspReference",
      "@type": "xsd:string"
    },
    "resultCode": {
      "@id": "adyen:resultCode",
      "@type": "xsd:string"
    }
  }
}