{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "Response": "adyen:Response",
    "Result": {
      "@id": "adyen:Result",
      "@type": "xsd:string"
    },
    "ErrorCondition": {
      "@id": "adyen:ErrorCondition",
      "@type": "xsd:string"
    },
    "AdditionalResponse": {
      "@id": "adyen:AdditionalResponse",
      "@type": "xsd:string"
    }
  }
}