{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "OutputContent": "adyen:OutputContent",
    "OutputFormat": {
      "@id": "adyen:OutputFormat",
      "@type": "xsd:string"
    },
    "PredefinedContent": {
      "@id": "adyen:PredefinedContent",
      "@type": "xsd:string"
    },
    "OutputText": {
      "@id": "adyen:OutputText",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "OutputXHTML": {
      "@id": "adyen:OutputXHTML",
      "@type": "xsd:string"
    },
    "OutputBarcode": {
      "@id": "adyen:OutputBarcode",
      "@type": "xsd:string"
    }
  }
}