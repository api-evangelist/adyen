{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "OrderItem": "adyen:OrderItem",
    "id": {
      "@id": "adyen:id",
      "@type": "xsd:string"
    },
    "installments": {
      "@id": "adyen:installments",
      "@type": "xsd:integer"
    },
    "name": "schema:name",
    "quantity": {
      "@id": "adyen:quantity",
      "@type": "xsd:integer"
    }
  }
}