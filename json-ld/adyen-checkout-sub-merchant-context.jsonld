{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "SubMerchantInfo": "adyen:SubMerchantInfo",
    "SubMerchant": "adyen:SubMerchant",
    "address": {
      "@id": "adyen:address",
      "@type": "xsd:string"
    },
    "id": {
      "@id": "adyen:id",
      "@type": "xsd:string"
    },
    "mcc": {
      "@id": "adyen:mcc",
      "@type": "xsd:string"
    },
    "name": "schema:name",
    "taxId": {
      "@id": "adyen:taxId",
      "@type": "xsd:string"
    },
    "city": {
      "@id": "adyen:city",
      "@type": "xsd:string"
    },
    "country": {
      "@id": "adyen:country",
      "@type": "xsd:string"
    }
  }
}