{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "ContactDetails": "adyen:ContactDetails",
    "address": {
      "@id": "adyen:address",
      "@type": "xsd:string"
    },
    "email": "schema:email",
    "phone": {
      "@id": "adyen:phone",
      "@type": "xsd:string"
    },
    "webAddress": {
      "@id": "adyen:webAddress",
      "@type": "xsd:string"
    }
  }
}