{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "IdentificationData": "adyen:IdentificationData",
    "cardNumber": {
      "@id": "adyen:cardNumber",
      "@type": "xsd:string"
    },
    "expiryDate": {
      "@id": "adyen:expiryDate",
      "@type": "xsd:string"
    },
    "issuerCountry": {
      "@id": "adyen:issuerCountry",
      "@type": "xsd:string"
    },
    "issuerState": {
      "@id": "adyen:issuerState",
      "@type": "xsd:string"
    },
    "nationalIdExempt": {
      "@id": "adyen:nationalIdExempt",
      "@type": "xsd:boolean"
    },
    "number": {
      "@id": "adyen:number",
      "@type": "xsd:string"
    },
    "type": {
      "@id": "adyen:type",
      "@type": "xsd:string"
    }
  }
}