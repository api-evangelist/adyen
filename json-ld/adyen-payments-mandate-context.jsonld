    },
    "billingAttemptsRule": {
      "@id": "adyen:billingAttemptsRule",
      "@type": "xsd:string"
    },
    "billingDay": {
      "@id": "adyen:billingDay",
      "@type": "xsd:string"
    },
    "endsAt": {
      "@id": "adyen:endsAt",
      "@type": "xsd:string"
    },
    "frequency": {
      "@id": "adyen:frequency",
      "@type": "xsd:string"
    },
    "remarks": {
      "@id": "adyen:remarks",
      "@type": "xsd:string"
    },
    "startsAt": {
      "@id": "adyen:startsAt",
      "@type": "xsd:string"
    }
  }
}