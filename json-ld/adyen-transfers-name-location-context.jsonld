{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "NameLocation": "adyen:NameLocation",
    "city": {
      "@id": "adyen:city",
      "@type": "xsd:string"
    },
    "country": {
      "@id": "adyen:country",
      "@type": "xsd:string"
    },
    "countryOfOrigin": {
      "@id": "adyen:countryOfOrigin",
      "@type": "xsd:string"
    },
    "name": "schema:name",
    "rawData": {
      "@id": "adyen:rawData",
      "@type": "xsd:string"
    },
    "state": {
      "@id": "adyen:state",
      "@type": "xsd:string"
    }
  }
}