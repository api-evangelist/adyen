{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "ApiCredentialLinks": "adyen:ApiCredentialLinks",
    "ApiCredential": "adyen:ApiCredential",
    "allowedOrigins": {
      "@id": "adyen:allowedOrigins",
      "@type": "xsd:string"
    },
    "company": {
      "@id": "adyen:company",
      "@type": "xsd:string"
    },
    "generateApiKey": {
      "@id": "adyen:generateApiKey",
      "@type": "xsd:string"
    },
    "generateClientKey": {
      "@id": "adyen:generateClientKey",
      "@type": "xsd:string"
    },
    "merchant": {
      "@id": "adyen:merchant",
      "@type": "xsd:string"
    },
    "self": {
      "@id": "adyen:self",
      "@type": "xsd:string"
    },
    "Links": {
      "@id": "adyen:_links",
      "@type": "xsd:string"
    },
    "active": {
      "@id": "adyen:active",
      "@type": "xsd:boolean"
    },
    "allowedIpAddresses": {
      "@id": "adyen:allowedIpAddresses",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "clientKey": {
      "@id": "adyen:clientKey",
      "@type": "xsd:string"
    },
    "description": "schema:description",
    "id": {
      "@id": "adyen:id",
      "@type": "xsd:string"
    },
    "roles": {
      "@id": "adyen:roles",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "username": {
      "@id": "adyen:username",
      "@type": "xsd:string"
    }
  }
}