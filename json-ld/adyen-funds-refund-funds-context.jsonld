{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "RefundFundsTransferRequest": "adyen:RefundFundsTransferRequest",
    "RefundFundsTransferResponse": "adyen:RefundFundsTransferResponse",
    "amount": {
      "@id": "adyen:amount",
      "@type": "xsd:string"
    },
    "merchantReference": {
      "@id": "adyen:merchantReference",
      "@type": "xsd:string"
    },
    "originalReference": {
      "@id": "adyen:originalReference",
      "@type": "xsd:string"
    },
    "invalidFields": {
      "@id": "adyen:invalidFields",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "message": {
      "@id": "adyen:message",
      "@type": "xsd:string"
    },
    "pspReference": {
      "@id": "adyen:pspReference",
      "@type": "xsd:string"
    },
    "resultCode": {
      "@id": "adyen:resultCode",
      "@type": "xsd:string"
    }
  }
}