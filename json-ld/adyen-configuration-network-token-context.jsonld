    "NetworkToken": "adyen:NetworkToken",
    "brandVariant": {
      "@id": "adyen:brandVariant",
      "@type": "xsd:string"
    },
    "creationDate": {
      "@id": "adyen:creationDate",
      "@type": "xsd:dateTime"
    },
    "device": {
      "@id": "adyen:device",
      "@type": "xsd:string"
    },
    "id": {
      "@id": "adyen:id",
      "@type": "xsd:string"
    },
    "paymentInstrumentId": {
      "@id": "adyen:paymentInstrumentId",
      "@type": "xsd:string"
    },
    "status": {
      "@id": "adyen:status",
      "@type": "xsd:string"
    },
    "tokenLastFour": {
      "@id": "adyen:tokenLastFour",
      "@type": "xsd:string"
    },
    "type": {
      "@id": "adyen:type",
      "@type": "xsd:string"
    }
  }
}