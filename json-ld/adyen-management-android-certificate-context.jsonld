{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "AndroidCertificate": "adyen:AndroidCertificate",
    "description": "schema:description",
    "extension": {
      "@id": "adyen:extension",
      "@type": "xsd:string"
    },
    "id": {
      "@id": "adyen:id",
      "@type": "xsd:string"
    },
    "name": "schema:name",
    "notAfter": {
      "@id": "adyen:notAfter",
      "@type": "xsd:dateTime"
    },
    "notBefore": {
      "@id": "adyen:notBefore",
      "@type": "xsd:dateTime"
    },
    "status": {
      "@id": "adyen:status",
      "@type": "xsd:string"
    }
  }
}