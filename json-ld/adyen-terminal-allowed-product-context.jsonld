{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "AllowedProduct": "adyen:AllowedProduct",
    "ProductCode": {
      "@id": "adyen:ProductCode",
      "@type": "xsd:integer"
    },
    "EanUpc": {
      "@id": "adyen:EanUpc",
      "@type": "xsd:integer"
    },
    "ProductLabel": {
      "@id": "adyen:ProductLabel",
      "@type": "xsd:string"
    },
    "AdditionalProductInfo": {
      "@id": "adyen:AdditionalProductInfo",
      "@type": "xsd:string"
    }
  }
}