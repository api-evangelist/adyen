{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "InvalidField": "adyen:InvalidField",
    "message": {
      "@id": "adyen:message",
      "@type": "xsd:string"
    },
    "name": "schema:name",
    "value": {
      "@id": "adyen:value",
      "@type": "xsd:string"
    }
  }
}