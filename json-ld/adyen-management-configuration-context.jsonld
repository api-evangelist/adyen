{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "Configuration": "adyen:Configuration",
    "brand": {
      "@id": "adyen:brand",
      "@type": "xsd:string"
    },
    "country": {
      "@id": "adyen:country",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "currencies": {
      "@id": "adyen:currencies",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "sources": {
      "@id": "adyen:sources",
      "@container": "@set",
      "@type": "xsd:string"
    }
  }
}