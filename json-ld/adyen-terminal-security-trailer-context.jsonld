{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "SecurityTrailer": "adyen:SecurityTrailer",
    "AdyenCryptoVersion": {
      "@id": "adyen:AdyenCryptoVersion",
      "@type": "xsd:integer"
    },
    "KeyIdentifier": {
      "@id": "adyen:KeyIdentifier",
      "@type": "xsd:string"
    },
    "KeyVersion": {
      "@id": "adyen:KeyVersion",
      "@type": "xsd:integer"
    },
    "Nonce": {
      "@id": "adyen:Nonce",
      "@type": "xsd:string"
    },
    "Hmac": {
      "@id": "adyen:Hmac",
      "@type": "xsd:string"
    }
  }
}