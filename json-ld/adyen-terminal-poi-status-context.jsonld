    },
    "PEDOKFlag": {
      "@id": "adyen:PEDOKFlag",
      "@type": "xsd:boolean"
    },
    "CardReaderOKFlag": {
      "@id": "adyen:CardReaderOKFlag",
      "@type": "xsd:boolean"
    },
    "PrinterStatus": {
      "@id": "adyen:PrinterStatus",
      "@type": "xsd:string"
    },
    "CommunicationOKFlag": {
      "@id": "adyen:CommunicationOKFlag",
      "@type": "xsd:boolean"
    },
    "CashHandlingDevice": {
      "@id": "adyen:CashHandlingDevice",
      "@container": "@set",
