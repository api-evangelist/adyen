{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "TimeOfDayRestriction": "adyen:TimeOfDayRestriction",
    "TimeOfDay": "adyen:TimeOfDay",
    "operation": {
      "@id": "adyen:operation",
      "@type": "xsd:string"
    },
    "value": {
      "@id": "adyen:value",
      "@type": "xsd:string"
    },
    "endTime": {
      "@id": "adyen:endTime",
      "@type": "xsd:string"
    },
    "startTime": {
      "@id": "adyen:startTime",
      "@type": "xsd:string"
    }
  }
}