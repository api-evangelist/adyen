{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "Authentication": "adyen:Authentication",
    "email": "schema:email",
    "password": {
      "@id": "adyen:password",
      "@type": "xsd:string"
    },
    "phone": {
      "@id": "adyen:phone",
      "@type": "xsd:string"
    }
  }
}