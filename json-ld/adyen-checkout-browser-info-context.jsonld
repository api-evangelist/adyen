{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "BrowserInfo": "adyen:BrowserInfo",
    "acceptHeader": {
      "@id": "adyen:acceptHeader",
      "@type": "xsd:string"
    },
    "colorDepth": {
      "@id": "adyen:colorDepth",
      "@type": "xsd:integer"
    },
    "javaEnabled": {
      "@id": "adyen:javaEnabled",
      "@type": "xsd:boolean"
    },
    "javaScriptEnabled": {
      "@id": "adyen:javaScriptEnabled",
      "@type": "xsd:boolean"
    },
    "language": {
      "@id": "adyen:language",
      "@type": "xsd:string"
    },
    "screenHeight": {
      "@id": "adyen:screenHeight",
      "@type": "xsd:integer"
    },
    "screenWidth": {
      "@id": "adyen:screenWidth",
      "@type": "xsd:integer"
    },
    "timeZoneOffset": {
      "@id": "adyen:timeZoneOffset",
      "@type": "xsd:integer"
    },
    "userAgent": {
      "@id": "adyen:userAgent",
      "@type": "xsd:string"
    }
  }
}