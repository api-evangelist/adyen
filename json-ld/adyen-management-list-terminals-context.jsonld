{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "ListTerminalsResponse": "adyen:ListTerminalsResponse",
    "Links": {
      "@id": "adyen:_links",
      "@type": "xsd:string"
    },
    "data": {
      "@id": "adyen:data",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "itemsTotal": {
      "@id": "adyen:itemsTotal",
      "@type": "xsd:integer"
    },
    "pagesTotal": {
      "@id": "adyen:pagesTotal",
      "@type": "xsd:integer"
    }
  }
}