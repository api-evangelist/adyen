{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "Individual": "adyen:Individual",
    "birthData": {
      "@id": "adyen:birthData",
      "@type": "xsd:string"
    },
    "email": "schema:email",
    "identificationData": {
      "@id": "adyen:identificationData",
      "@type": "xsd:string"
    },
    "name": "schema:name",
    "nationality": {
      "@id": "adyen:nationality",
      "@type": "xsd:string"
    },
    "phone": {
      "@id": "adyen:phone",
      "@type": "xsd:string"
    },
    "residentialAddress": {
      "@id": "adyen:residentialAddress",
      "@type": "xsd:string"
    },
    "taxInformation": {
      "@id": "adyen:taxInformation",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "webData": {
      "@id": "adyen:webData",
      "@type": "xsd:string"
    }
  }
}