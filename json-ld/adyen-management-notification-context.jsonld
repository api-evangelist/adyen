{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "Notification": "adyen:Notification",
    "category": {
      "@id": "adyen:category",
      "@type": "xsd:string"
    },
    "details": {
      "@id": "adyen:details",
      "@type": "xsd:string"
    },
    "enabled": {
      "@id": "adyen:enabled",
      "@type": "xsd:boolean"
    },
    "showButton": {
      "@id": "adyen:showButton",
      "@type": "xsd:boolean"
    },
    "title": {
      "@id": "adyen:title",
      "@type": "xsd:string"
    }
  }
}