{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "CheckoutSessionInstallmentOption": "adyen:CheckoutSessionInstallmentOption",
    "plans": {
      "@id": "adyen:plans",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "preselectedValue": {
      "@id": "adyen:preselectedValue",
      "@type": "xsd:integer"
    },
    "values": {
      "@id": "adyen:values",
      "@container": "@set",
      "@type": "xsd:integer"
    }
  }
}