{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "CapitalBalance": "adyen:CapitalBalance",
    "currency": {
      "@id": "adyen:currency",
      "@type": "xsd:string"
    },
    "fee": {
      "@id": "adyen:fee",
      "@type": "xsd:integer"
    },
    "principal": {
      "@id": "adyen:principal",
      "@type": "xsd:integer"
    },
    "total": {
      "@id": "adyen:total",
      "@type": "xsd:integer"
    }
  }
}