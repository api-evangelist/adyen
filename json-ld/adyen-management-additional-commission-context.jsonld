{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "AdditionalCommission": "adyen:AdditionalCommission",
    "balanceAccountId": {
      "@id": "adyen:balanceAccountId",
      "@type": "xsd:string"
    },
    "fixedAmount": {
      "@id": "adyen:fixedAmount",
      "@type": "xsd:integer"
    },
    "variablePercentage": {
      "@id": "adyen:variablePercentage",
      "@type": "xsd:integer"
    }
  }
}