{
  "@context": {
    "@version": 1.1,
    "adyen": "https://docs.adyen.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "Profile": "adyen:Profile",
    "authType": {
      "@id": "adyen:authType",
      "@type": "xsd:string"
    },
    "autoWifi": {
      "@id": "adyen:autoWifi",
      "@type": "xsd:boolean"
    },
    "bssType": {
      "@id": "adyen:bssType",
      "@type": "xsd:string"
    },
    "channel": {
      "@id": "adyen:channel",
      "@type": "xsd:integer"
    },
    "defaultProfile": {
      "@id": "adyen:defaultProfile",
      "@type": "xsd:boolean"
    },
    "eap": {
      "@id": "adyen:eap",
      "@type": "xsd:string"
    },
    "eapCaCert": {
      "@id": "adyen:eapCaCert",
      "@type": "xsd:string"
    },
    "eapClientCert": {
      "@id": "adyen:eapClientCert",
      "@type": "xsd:string"
    },
    "eapClientKey": {
      "@id": "adyen:eapClientKey",
      "@type": "xsd:string"
    },
    "eapClientPwd": {
      "@id": "adyen:eapClientPwd",
      "@type": "xsd:string"
    },
    "eapIdentity": {
      "@id": "adyen:eapIdentity",
      "@type": "xsd:string"
    },
    "eapIntermediateCert": {
      "@id": "adyen:eapIntermediateCert",
      "@type": "xsd:string"
    },
    "eapPwd": {
      "@id": "adyen:eapPwd",
      "@type": "xsd:string"
    },
    "hiddenSsid": {
      "@id": "adyen:hiddenSsid",
      "@type": "xsd:boolean"
    },
    "name": "schema:name",
    "psk": {
      "@id": "adyen:psk",
      "@type": "xsd:string"
    },
    "ssid": {
      "@id": "adyen:ssid",
      "@type": "xsd:string"
    },
    "wsec": {
      "@id": "adyen:wsec",
      "@type": "xsd:string"
    }
  }
}