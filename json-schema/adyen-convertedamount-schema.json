{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/ConvertedAmount",
  "title": "ConvertedAmount",
  "type": "object",
  "properties": {
    "AmountValue": {
      "type": "number",
      "maximum": 99999999.999999,
      "minimum": 0
    },
    "Currency": {
      "type": "string",
      "pattern": "^[A-Z]{3,3}$"
    }
  },
  "required": [
    "AmountValue",
    "Currency"
  ]
}