{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/ServiceError",
  "title": "ServiceError",
  "properties": {
    "errorCode": {
      "description": "The error code mapped to the error message.",
      "type": "string"
    },
    "errorType": {
