{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/adyen/refs/heads/main/json-schema/terminal-rebates-schema.json",
  "title": "Rebates",
  "description": "Rebates schema from Adyen API",
  "type": "object",
  "properties": {
    "TotalRebate": {
      "type": "number",
      "maximum": 99999999.999999,
      "minimum": 0
    },
    "RebateLabel": {
      "type": "string",
      "pattern": "^.+$"
    },
    "SaleItemRebate": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/SaleItemRebate"
      }
    }
  }
}