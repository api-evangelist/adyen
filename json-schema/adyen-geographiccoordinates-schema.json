{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/GeographicCoordinates",
  "title": "GeographicCoordinates",
  "type": "object",
  "properties": {
    "Latitude": {
      "type": "string",
      "pattern": "^.+$"
    },
    "Longitude": {
      "type": "string",
      "pattern": "^.+$"
    }
  },
  "required": [
    "Latitude",
    "Longitude"
  ]
}