{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/LoyaltyAccountStatus",
  "title": "LoyaltyAccountStatus",
  "type": "object",
  "properties": {
    "LoyaltyAccount": {
      "$ref": "#/components/schemas/LoyaltyAccount"
    },
    "CurrentBalance": {
      "type": "number",
      "maximum": 99999999.999999,
      "minimum": 0
    },
    "LoyaltyUnit": {
      "$ref": "#/components/schemas/LoyaltyUnit"
    },
    "Currency": {
      "type": "string",
      "pattern": "^[A-Z]{3,3}$"
    }
  },
  "required": [
    "LoyaltyAccount"
  ]
}