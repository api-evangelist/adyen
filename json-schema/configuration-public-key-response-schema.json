{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/adyen/refs/heads/main/json-schema/configuration-public-key-response-schema.json",
  "title": "PublicKeyResponse",
  "description": "PublicKeyResponse schema from Adyen API",
  "type": "object",
  "properties": {
    "publicKey": {
      "description": "The public key to be used for encrypting the symmetric session key.",
      "type": "string"
    },
    "publicKeyExpiryDate": {
      "description": "The expiry date of the public key.",
      "type": "string"
    }
  },
  "required": [
    "publicKey",
    "publicKeyExpiryDate"
  ]
}