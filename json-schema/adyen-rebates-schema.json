{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Rebates",
  "title": "Rebates",
  "type": "object",
  "properties": {
    "TotalRebate": {
      "type": "number",
      "maximum": 99999999.999999,
      "minimum": 0
    },
    "RebateLabel": {
      "type": "string",
      "pattern": "^.+$"
    },
    "SaleItemRebate": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/SaleItemRebate"
      }
    }
  }
}