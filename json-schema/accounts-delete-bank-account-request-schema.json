{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/adyen/refs/heads/main/json-schema/accounts-delete-bank-account-request-schema.json",
  "title": "DeleteBankAccountRequest",
  "description": "DeleteBankAccountRequest schema from Adyen API",
  "type": "object",
  "properties": {
    "accountHolderCode": {
      "description": "The code of the Account Holder from which to delete the Bank Account(s).",
      "type": "string"
    },
    "bankAccountUUIDs": {
      "description": "The code(s) of the Bank Accounts to be deleted.",
      "items": {
        "type": "string"
      },
      "type": "array"
    }
  },
  "required": [
    "accountHolderCode",
    "bankAccountUUIDs"
  ]
}