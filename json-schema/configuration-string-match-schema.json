{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/adyen/refs/heads/main/json-schema/configuration-string-match-schema.json",
  "title": "StringMatch",
  "description": "StringMatch schema from Adyen API",
  "type": "object",
  "properties": {
    "operation": {
      "description": "The type of string matching operation. Possible values:  **startsWith**, **endsWith**, **isEqualTo**, **contains**,",
      "enum": [
        "contains",
        "endsWith",
        "isEqualTo",
        "startsWith"
      ],
      "type": "string"
    },
    "value": {
      "description": "The string to be matched.",
      "type": "string"
    }
  }
}