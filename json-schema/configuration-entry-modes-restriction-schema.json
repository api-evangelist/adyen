{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/adyen/refs/heads/main/json-schema/configuration-entry-modes-restriction-schema.json",
  "title": "EntryModesRestriction",
  "description": "EntryModesRestriction schema from Adyen API",
  "type": "object",
  "properties": {
    "operation": {
      "description": "Defines how the condition must be evaluated.",
      "type": "string"
    },
    "value": {
      "description": "List of point-of-sale entry modes.\n\nPossible values: **barcode**, **chip**, **cof**, **contactless**, **magstripe**, **manual**, **ocr**, **server**.\n\n",
      "items": {
        "enum": [
          "barcode",
          "chip",
          "cof",
          "contactless",
          "magstripe",
          "manual",
          "ocr",
          "server",
          "unknown"
        ],
        "type": "string"
      },
      "type": "array"
    }
  },
  "required": [
    "operation"
  ]
}