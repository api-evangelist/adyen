    },
    "id": {
      "description": "The identifier of the grant account.",
      "type": "string"
    },
    "limits": {
      "description": "The limits of the grant account.",
      "items": {
        "$ref": "#/components/schemas/GrantLimit"
      },
      "type": "array"
    }
  }
}