{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/DeviceRenderOptions",
  "title": "DeviceRenderOptions",
  "properties": {
    "sdkInterface": {
      "default": "both",
      "description": "Supported SDK interface types.\nAllowed values:\n* native\n* html\n* both",
      "enum": [
        "native",
        "html",
        "both"
      ],
      "type": "string"
    },
    "sdkUiType": {
      "description": "UI types supported for displaying specific challenges.\nAllowed values:\n* text\n* singleSelect\n* outOfBand\n* otherHtml\n* multiSelect",
      "items": {
        "enum": [
          "multiSelect",
          "otherHtml",
          "outOfBand",
          "singleSelect",
          "text"
        ],
        "type": "string"
      },
      "type": "array"
    }
  },
  "type": "object"
}