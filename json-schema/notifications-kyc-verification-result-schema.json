{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/adyen/refs/heads/main/json-schema/notifications-kyc-verification-result-schema.json",
  "title": "KYCVerificationResult",
  "description": "KYCVerificationResult schema from Adyen API",
  "type": "object",
  "properties": {
