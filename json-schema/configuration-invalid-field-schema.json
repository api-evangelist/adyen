{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/adyen/refs/heads/main/json-schema/configuration-invalid-field-schema.json",
  "title": "InvalidField",
  "description": "InvalidField schema from Adyen API",
  "type": "object",
  "properties": {
    "message": {
      "description": "Description of the validation error.",
      "type": "string"
    },
    "name": {
      "description": "The field that has an invalid value.",
      "type": "string"
    },
    "value": {
      "description": "The invalid value.",
      "type": "string"
    }
  },
  "required": [
    "name",
    "value",
    "message"
  ]
}