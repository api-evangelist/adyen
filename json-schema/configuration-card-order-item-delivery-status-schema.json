{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/adyen/refs/heads/main/json-schema/configuration-card-order-item-delivery-status-schema.json",
  "title": "CardOrderItemDeliveryStatus",
  "description": "CardOrderItemDeliveryStatus schema from Adyen API",
  "type": "object",
  "properties": {
    "errorMessage": {
      "description": "An error message.",
      "type": "string"
    },
    "status": {
      "description": "The status of the PIN delivery.",
      "enum": [
        "created",
        "delivered",
        "notApplicable",
        "processing",
        "produced",
        "rejected",
        "shipped",
        "unknown"
      ],
      "type": "string"
    },
    "trackingNumber": {
      "description": "The tracking number of the PIN delivery.",
      "type": "string"
    }
  }
}