{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/SoundContent",
  "title": "SoundContent",
  "type": "object",
  "properties": {
    "SoundFormat": {
      "$ref": "#/components/schemas/SoundFormat"
    },
    "Language": {
      "type": "string",
      "pattern": "^[a-z]{2,2}$"
    },
    "ReferenceID": {
      "type": "string",
      "pattern": "^.+$"
    },
    "Text": {
      "type": "string",
      "pattern": "^.+$"
    }
  },
  "required": [
    "SoundFormat"
  ]
}