{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/adyen/refs/heads/main/json-schema/transfers-capital-balance-schema.json",
  "title": "CapitalBalance",
  "description": "CapitalBalance schema from Adyen API",
  "type": "object",
  "properties": {
    "currency": {
      "description": "The three-character [ISO currency code](https://docs.adyen.com/development-resources/currency-codes).",
      "type": "string"
    },
    "fee": {
      "description": "Fee amount.",
      "format": "int64",
      "type": "integer"
    },
    "principal": {
      "description": "Principal amount.",
      "format": "int64",
      "type": "integer"
    },
    "total": {
      "description": "Total amount. A sum of principal amount and fee amount.",
      "format": "int64",
      "type": "integer"
    }
  },
  "required": [
    "principal",
    "fee",
    "total",
    "currency"
  ]
}