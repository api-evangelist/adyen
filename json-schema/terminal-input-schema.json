{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/adyen/refs/heads/main/json-schema/terminal-input-schema.json",
  "title": "Input",
  "description": "Input schema from Adyen API",
  "type": "object",
  "properties": {
    "InputCommand": {
      "$ref": "#/components/schemas/InputCommand"
    },
    "ConfirmedFlag": {
      "type": "boolean"
    },
    "FunctionKey": {
      "type": "integer"
    },
    "TextInput": {
      "type": "string"
    },
    "DigitInput": {
      "type": "integer"
    },
    "Password": {
      "type": "string"
    },
    "MenuEntryNumber": {
      "type": "array",
      "items": {
        "type": "integer"
      }
    }
  },
  "required": [
    "InputCommand"
  ]
}