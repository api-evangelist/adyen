{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/adyen/refs/heads/main/json-schema/terminal-poi-software-schema.json",
  "title": "POISoftware",
  "description": "POISoftware schema from Adyen API",
  "type": "object",
  "properties": {
    "ManufacturerID": {
      "type": "string",
      "pattern": "^.+$"
    },
    "ApplicationName": {
      "type": "string",
      "pattern": "^.+$"
    },
    "SoftwareVersion": {
      "type": "string",
      "pattern": "^.+$"
    },
    "CertificationCode": {
      "type": "string",
      "pattern": "^.+$"
    }
  },
  "required": [
    "ManufacturerID",
    "ApplicationName",
    "SoftwareVersion",
    "CertificationCode"
  ]
}