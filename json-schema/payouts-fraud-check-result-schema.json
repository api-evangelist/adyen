{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/adyen/refs/heads/main/json-schema/payouts-fraud-check-result-schema.json",
  "title": "FraudCheckResult",
  "description": "FraudCheckResult schema from Adyen API",
  "type": "object",
  "properties": {
    "accountScore": {
      "description": "The fraud score generated by the risk check.",
      "format": "int32",
      "type": "integer"
    },
    "checkId": {
      "description": "The ID of the risk check.",
      "format": "int32",
      "type": "integer"
    },
    "name": {
      "description": "The name of the risk check.",
      "type": "string"
    }
  },
  "required": [
    "checkId",
    "name",
    "accountScore"
  ]
}