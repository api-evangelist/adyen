{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/adyen/refs/heads/main/json-schema/checkout-company-schema.json",
  "title": "Company",
  "description": "Company schema from Adyen API",
  "type": "object",
  "properties": {
    "homepage": {
      "description": "The company website's home page.",
      "type": "string"
    },
    "name": {
      "description": "The company name.",
      "type": "string"
    },
    "registrationNumber": {
      "description": "Registration number of the company.",
      "type": "string"
    },
    "registryLocation": {
      "description": "Registry location of the company.",
      "type": "string"
    },
    "taxId": {
      "description": "Tax ID of the company.",
      "type": "string"
    },
    "type": {
      "description": "The company type.",
      "type": "string"
    }
  }
}