{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/adyen/refs/heads/main/json-schema/payments-fraud-result-schema.json",
  "title": "FraudResult",
  "description": "FraudResult schema from Adyen API",
  "type": "object",
  "properties": {
    "accountScore": {
      "description": "The total fraud score generated by the risk checks.",
      "format": "int32",
      "type": "integer"
    },
    "results": {
      "description": "The result of the individual risk checks.",
      "items": {
        "$ref": "#/components/schemas/FraudCheckResultWrapper"
      },
      "type": "array"
    }
  },
  "required": [
    "accountScore"
  ]
}