{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/AmountsResp",
  "title": "AmountsResp",
  "type": "object",
  "properties": {
    "Currency": {
      "type": "string",
      "pattern": "^[A-Z]{3,3}$"
    },
    "AuthorizedAmount": {
      "type": "number",
      "maximum": 99999999.999999,
      "minimum": 0
    },
    "TotalRebatesAmount": {
      "type": "number",
      "maximum": 99999999.999999,
      "minimum": 0
    },
    "TotalFeesAmount": {
      "type": "number",
      "maximum": 99999999.999999,
      "minimum": 0
    },
    "CashBackAmount": {
      "type": "number",
      "maximum": 99999999.999999,
      "minimum": 0
    },
    "TipAmount": {
      "type": "number",
      "maximum": 99999999.999999,
      "minimum": 0
    }
  },
  "required": [
    "AuthorizedAmount"
  ]
}