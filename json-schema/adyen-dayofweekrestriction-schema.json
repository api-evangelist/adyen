      "items": {
        "enum": [
          "friday",
          "monday",
          "saturday",
          "sunday",
          "thursday",
          "tuesday",
          "wednesday"
        ],
        "type": "string"
      },
      "type": "array"
    }
  },
  "required": [
    "operation"
  ],
  "type": "object"
}