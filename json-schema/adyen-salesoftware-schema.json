{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/SaleSoftware",
  "title": "SaleSoftware",
  "type": "object",
  "description": "Information related to the software of the Sale System which manages the NEXO Sale to POI protocol.",
  "properties": {
    "ManufacturerID": {
      "type": "string",
      "pattern": "^.+$"
    },
    "ApplicationName": {
      "type": "string",
      "pattern": "^.+$"
    },
    "SoftwareVersion": {
      "type": "string",
      "pattern": "^.+$"
    },
    "CertificationCode": {
      "type": "string",
      "pattern": "^.+$"
    }
  },
  "required": [
    "ManufacturerID",
    "ApplicationName",
    "SoftwareVersion",
    "CertificationCode"
  ]
}