{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/adyen/refs/heads/main/json-schema/terminal-utm-coordinates-schema.json",
  "title": "UTMCoordinates",
  "description": "UTMCoordinates schema from Adyen API",
  "type": "object",
  "properties": {
    "UTMZone": {
      "type": "string",
      "pattern": "^.+$"
    },
    "UTMEastward": {
      "type": "string",
      "pattern": "^.+$"
    },
    "UTMNorthward": {
      "type": "string",
      "pattern": "^.+$"
    }
  },
  "required": [
    "UTMZone",
    "UTMEastward",
    "UTMNorthward"
  ]
}